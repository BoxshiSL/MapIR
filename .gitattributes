# Default behavior — normalize text on commit, auto-detect binary
* text=auto

# Source files — always LF in the repo, even on Windows checkouts
*.py        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.svg       text eol=lf
*.obj       text eol=lf
*.spec      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Windows-only scripts — must keep CRLF for cmd.exe
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.zip       binary
*.7z        binary
*.pdf       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
